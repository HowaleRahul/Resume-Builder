{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite",
      "config": {
        "distDir": "dist"
      }
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  },

  "buildCommand": "npm run build --workspaces",
  "outputDirectory": "frontend/dist",

  "env": {
    "NODE_ENV": "production",
    "LOG_LEVEL": "error",
    "ENABLE_FILE_LOGGING": "false"
  },

  "rewrites": [
    {
      "source": "/:path((?!_/backend|_next/static|_next/image|favicon.ico).*)",
      "destination": "/index.html"
    }
  ],

  "redirects": [
    {
      "source": "/api/:path*",
      "destination": "/_/backend/api/:path*",
      "permanent": false
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],

  "cleanUrls": true,
  "trailingSlash": false
}
